generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PurchaseStatus {
  id                Int      @id @default(autoincrement())
  lineItemId        Int      @unique
  orderId           Int
  isPurchased       Boolean  @default(false)
  quantityPurchased Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([orderId])
}

model PurchaseStatusBySupplier {
  lineItemId   Int
  supplierId   String
  orderId      Int
  quantity     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@id([lineItemId, supplierId])
  @@index([lineItemId])
  @@index([orderId])
}

// ---------- Usuarios ----------
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  nombre       String   @default("")
  passwordHash String
  permissions  Json     @default("{}")
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------- Proveedores ----------
model Supplier {
  id        String            @id @default(cuid())
  name      String
  contact   String            @default("")
  phone     String            @default("")
  zones     String            @default("[]")
  website   String            @default("")
  notes     String            @default("")
  locations String            @default("[]")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  articles  ArticleSupplier[]
  tickets   SupplierTicket[]
}

// ---------- Artículos ----------
model Article {
  id           String            @id @default(cuid())
  wooProductId Int?              @unique
  name         String
  image        String?
  price        Float
  sku          String            @default("")
  barcode      String            @default("")
  category     String            @default("")
  description  String            @default("")
  stockStatus  String            @default("")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  suppliers    ArticleSupplier[]
  inventory    InventoryItem?
}

model ArticleSupplier {
  articleId  String
  supplierId String
  zone       String   @default("")
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([articleId, supplierId])
}

// ---------- Recetas ----------
model Recipe {
  id           String               @id @default(cuid())
  name         String
  description  String               @default("")
  recipeType   String               @default("alimento") // 'alimento' | 'bebida' | 'otros'
  category     String               // 'caliente' | 'fria' | 'especial'
  drinkTemps   String               @default("[]")      // JSON: ('fria'|'caliente')[] — only for bebida
  image        String?
  instructions String               @default("")
  servings     Int                  @default(1)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  ingredients  RecipeIngredient[]
  sizeVariants RecipeSizeVariant[]
}

model RecipeIngredient {
  id       Int    @id @default(autoincrement())
  recipeId String
  name     String
  quantity String
  unit     String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model RecipeSizeVariant {
  id          Int                        @id @default(autoincrement())
  recipeId    String
  temp        String                     // 'fria' | 'caliente'
  size        String                     // '10oz' | '12oz' | '16oz'
  recipe      Recipe                     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredients RecipeSizeIngredient[]
}

model RecipeSizeIngredient {
  id       Int               @id @default(autoincrement())
  variantId Int
  name     String
  quantity String
  unit     String
  variant  RecipeSizeVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

// ---------- Pedidos de Tienda ----------
model StoreOrder {
  id            Int              @id @default(autoincrement())
  dateCreated   DateTime         @default(now())
  status        String           @default("pending")
  customerName  String
  customerPhone String
  notes         String           @default("")
  total         Float
  items         StoreOrderItem[]
}

model StoreOrderItem {
  id                Int        @id @default(autoincrement())
  orderId           Int
  articleId         String
  name              String
  price             Float
  qty               Int
  isPurchased       Boolean    @default(false)
  quantityPurchased Int        @default(0)
  imageUrl          String?
  supplierName      String     @default("Sin proveedor")
  supplierId        String?
  order             StoreOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, articleId])
}

// ---------- Tickets de pedido ----------
model OrderTicket {
  id           String   @id @default(cuid())
  orderId      Int
  supplierName String
  invoiced     Boolean  @default(false)
  filename     String
  mimeType     String
  size         Int
  content      String
  createdAt    DateTime @default(now())

  @@index([orderId])
  @@index([orderId, supplierName])
}

// ---------- Inventario ----------
model InventoryItem {
  id         String              @id @default(cuid())
  articleId  String              @unique
  stock      Float               @default(0)
  stockMin   Float               @default(0)
  unit       String              @default("unidad")
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  article    Article             @relation(fields: [articleId], references: [id], onDelete: Cascade)
  movements  InventoryMovement[]
}

model InventoryMovement {
  id              String        @id @default(cuid())
  inventoryItemId String
  type            String
  quantity        Float
  reason          String        @default("")
  userId          String
  userName        String
  createdAt       DateTime      @default(now())
  item            InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
}

// ---------- Configuración de empresa ----------
model CompanySettings {
  id        Int      @id @default(1)
  name      String   @default("")
  logo      String?
  updatedAt DateTime @updatedAt
}

// ---------- Tickets de proveedor ----------
model SupplierTicket {
  id         String   @id @default(cuid())
  supplierId String
  orderRef   String   @default("")
  invoiced   Boolean  @default(false)
  filename   String
  mimeType   String
  size       Int
  content    String
  createdAt  DateTime @default(now())

  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}
